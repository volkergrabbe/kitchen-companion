<!--
  Kitchen Companion v2.0 — Data Extraction Rules

  Leere Regeln für Cloud-Backup und Device-to-Device-Transfer.
  Begründung (P0-2 aus KH Privacy Review): Die App speichert sensible
  Daten (Kontraindikationen = Krankheiten/Medikamente, PLZ, API-Key).
  Diese sollen weder ins Google-Drive-Backup noch via D2D-Transfer
  das Gerät verlassen.

  Mit leeren <include>-Sets wird NICHTS extrahiert.
-->
<data-extraction-rules>
    <cloud-backup>
        <!-- Bewusst leer: kein Cloud-Backup. -->
    </cloud-backup>
    <device-transfer>
        <!-- Bewusst leer: kein Device-to-Device-Transfer. -->
    </device-transfer>
</data-extraction-rules>
